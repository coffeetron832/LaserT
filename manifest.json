{
  "manifest_version": 3,
  "name": "LáserT",
  "version": "1.1",
  "description": "Traduce texto con un escaneo láser desde el menú contextual.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "lasert-translator@tuproyecto.local"
    }
  }
}
